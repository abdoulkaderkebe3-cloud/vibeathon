# ─────────────────────────────────────────────────────────────
#  EcoWatt — fichiers à ne JAMAIS versionner
# ─────────────────────────────────────────────────────────────

# Secrets (NON NÉGOCIABLE : la clé API ne doit jamais partir avec le code)
.env
.env.*
!.env.example
# Exception : configuration du build vitrine, aucun secret dedans (un seul drapeau public).
!.env.vitrine
*.key
secrets/

# Python (backend)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Base de données locale (données de démo, régénérée au lancement)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# État runtime spécifique au boîtier (tare des capteurs), régénéré à la demande
tare_bruit.json

# Node / front (app)
node_modules/
dist/
dist-vitrine/
dist-ssr/
*.local
*.log
tsconfig.tsbuildinfo
.vite/
coverage/

# Firmware ESP32 (PlatformIO)
.pio/
.pioenvs/
.piolibdeps/

# Firmware — identifiants WiFi locaux (jamais committés, voir arduino_secrets.h.example)
arduino_secrets.h

# Éditeurs / OS
.idea/
*.swp
.DS_Store
Thumbs.db

# Notes de travail locales (continuité de session, non destinées au dépôt public)
CLAUDE.md
PROGRESS.md
NEXT_SESSION.md
# Notes internes à la racine ; le dépôt publie la version assainie docs/DECISIONS.md
/DECISIONS.md
docs/SOUMISSION.md
docs/reference/
Ecowatt.pdf
