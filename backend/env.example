# Copie ce fichier en .env (gitignored) et remplis les valeurs :  cp env.example .env
# En prod on génère le .env via /generer-env depuis le coffre ../../secrets/api-keys.md

# --- Cerveau IA : cascade de fournisseurs (brain._providers) ---
# On essaie les modèles dans l'ordre ; dès qu'un sature (429) ou tombe, on passe au suivant,
# de façon invisible pour l'utilisateur. En dernier recours : règles déterministes (hors ligne).

# Groq (prioritaire, tool calling natif) -> clé sur console.groq.com (gratuit, rapide, LPU).
# Le quota gratuit est compté PAR MODÈLE : chaque modèle de la liste est un filet supplémentaire.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b,openai/gpt-oss-20b

# Google Gemini (secours, tier gratuit généreux) -> clé sur aistudio.google.com
# ⚠️ Catalogue volatil : vérifier par un VRAI appel, la liste /v1beta/models annonce encore des
# modèles retirés. Au 2026-07-09 : 2.5-flash et 2.5-flash-lite = 404 (retirés), 2.0-flash* = 429,
# flash-latest et 3.5-flash = 503. Les modèles ci-dessous répondent et supportent le tool calling.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_MODELS=gemini-flash-lite-latest,gemini-3.1-flash-lite

# Mistral (secours optionnel, français) -> clé sur console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# OpenRouter (dernier fallback) -> clé sur openrouter.ai
# Laisse toutes les clés vides pour forcer le mode mock (règles locales, aucun appel réseau).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ECOWATT_MODEL=openai/gpt-oss-20b:free

# Mode mock : 1 = décisions IA simulées en local (aucun appel réseau), 0 = vrais appels
ECOWATT_MOCK=1

# Fenêtre "heure de pointe" locale (heures pleines), format 24h
ECOWATT_PEAK_START=18
ECOWATT_PEAK_END=22

# Seuil de puissance (W) au-dessus duquel une mesure est considérée comme un "pic"
ECOWATT_PIC_WATTS=800

# Paramètres d'impact (à sourcer, voir docs/impact.md)
ECOWATT_PRIX_KWH_FCFA=79
ECOWATT_CO2_KG_PAR_KWH=0.5

# --- Matériel (ESP32) ---
# IP du boîtier ESP32 sur le réseau local (serveur HTTP embarqué)
ECOWATT_HARDWARE_URL=http://192.168.1.153
