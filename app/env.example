# Copie en .env.local (gitignored) :  cp env.example .env.local

# URL du WebSocket backend (dashboard). Défaut : ws://localhost:8000/ws/app
VITE_WS_URL=ws://localhost:8000/ws/app

# Mode démo (défaut) : simulateur local sans backend qui rejoue le scénario.
# Mets VITE_MOCK=0 UNIQUEMENT pour te brancher sur le vrai backend FastAPI.
VITE_MOCK=1
